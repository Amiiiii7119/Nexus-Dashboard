{
  "name": "nexus-erp-fullstack",
  "version": "2.0.0",
  "private": true,
  "description": "Nexus ERP — Full-stack internship management system",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd internship-erp && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd internship-erp && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build",
    "start:backend": "cd internship-erp && npm start",
    "start:frontend": "cd frontend && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
